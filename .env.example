# TradingView 数据源配置（可选，登录后可获取更多历史数据）
TV_USERNAME=
TV_PASSWORD=
# 拉数重试：单次请求最多 TV_FETCH_RETRIES+1 次；整轮（5m+1d）最多 TV_FETCH_ROUND_RETRIES+1 次
TV_FETCH_RETRIES=3
TV_FETCH_RETRY_BASE_S=2.0
TV_FETCH_ROUND_RETRIES=1
TV_SYMBOL=XAUUSD
TV_EXCHANGE=OANDA

# External data (News / DXY / Calendar / Social)
FINNHUB_API_KEY=
TE_CALENDAR_ENABLED=true
TE_CALENDAR_COUNTRY=united states
TE_CALENDAR_DAYS=2
TE_CALENDAR_MIN_IMPORTANCE=2
TV_DXY_EXCHANGE=TVC
TV_DXY_SYMBOL=DXY
NEWS_RSS_ENABLED=true
TV_SOCIAL_ENABLED=true
TV_SOCIAL_SYMBOL=XAUUSD
TV_SOCIAL_IDEAS_LIMIT=25
TV_SOCIAL_MINDS_LIMIT=15
EXTERNAL_HTTP_TIMEOUT=15
EXTERNAL_HTTP_RETRIES=2

PROJECT_NAME=GoldAnalysisAI
GITHUB_REPO=github.com/vbqx/GoldAnalysisAI
WATERMARK_TEXT=GoldAnalysisAI

# 日志：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_FILE=logs/goldanalysisai.log

# LLM 分析（默认关闭）
# 硅基流动示例：
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro
# LLM_MODEL_FAST=deepseek-ai/DeepSeek-V4-Pro
# LLM_MODEL_STRONG=deepseek-ai/DeepSeek-V4-Pro
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o-mini
LLM_TIMEOUT=120
LLM_ENHANCE_CONCLUSION=true

# 智能体流水线模式：rule | llm | hybrid
AGENT_MODE=rule
LLM_OVERRIDE_THRESHOLD=0.65
LLM_STAGE_RESEARCH=false
LLM_STAGE_DEBATE=false
LLM_STAGE_ANALYSTS=false
LLM_STAGE_ICT=false
LLM_STAGE_TRADER=false
LLM_STAGE_RISK=false
LLM_STAGE_MANAGER=false
