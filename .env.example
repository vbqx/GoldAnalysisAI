# TradingView 数据源配置（可选，登录后可获取更多历史数据）
TV_USERNAME=
TV_PASSWORD=
# 拉数重试：单次请求最多 TV_FETCH_RETRIES+1 次；整轮（5m+1d）最多 TV_FETCH_ROUND_RETRIES+1 次
TV_FETCH_RETRIES=3
TV_FETCH_RETRY_BASE_S=2.0
TV_FETCH_ROUND_RETRIES=1
TV_SYMBOL=XAUUSD
TV_EXCHANGE=OANDA

# Optional MT5 read-only market-data bridge (disabled by default; requires MetaTrader5 package + running terminal)
# Put real credentials only in local .env, never in committed files.
MT5_ENABLED=false
MT5_SYMBOL=XAUUSD
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# External data — 金十 MCP（快讯 + 资讯 + 财经日历）+ TradingView DXY / 社媒
# Token: https://mcp.jin10.com/app
JIN10_API_TOKEN=
JIN10_ENABLED=true
JIN10_MCP_URL=https://mcp.jin10.com/mcp
JIN10_MCP_PROTOCOL=2025-11-25
JIN10_KEYWORD=黄金
JIN10_FLASH_LIMIT=8
JIN10_ARTICLE_LIMIT=6
JIN10_NEWS_LIMIT=12
JIN10_CACHE_TTL=600
JIN10_MCP_TIMEOUT=60
TV_DXY_EXCHANGE=TVC
TV_DXY_SYMBOL=DXY
TV_US10Y_EXCHANGE=TVC
TV_US10Y_SYMBOL=US10Y
TV_SOCIAL_ENABLED=true
TV_SOCIAL_SYMBOL=XAUUSD
TV_SOCIAL_IDEAS_LIMIT=25
TV_SOCIAL_MINDS_LIMIT=15
EXTERNAL_HTTP_TIMEOUT=15
EXTERNAL_HTTP_RETRIES=2

# Analyst Team input density (payload / evidence caps)
ANALYST_NEWS_MAX=20
ANALYST_CALENDAR_MAX=12
ANALYST_SOCIAL_MAX=15
ANALYST_ICT_EVENTS_MAX=8
ANALYST_TEAM_ITEMS_MAX=16
PAYLOAD_EVIDENCE_MAX=20
LLM_MIN_ANALYST_ITEMS=4
JIN10_QUOTE_ENABLED=true
JIN10_QUOTE_CODE=XAUUSD
JIN10_KLINE_ENABLED=true
JIN10_KLINE_CODE=XAUUSD
JIN10_KLINE_COUNT=20
# JIN10_KLINE_PERIOD=   # optional integer; omit to use MCP default period

PROJECT_NAME=GoldAnalysisAI
GITHUB_REPO=github.com/vbqx/GoldAnalysisAI
WATERMARK_TEXT=GoldAnalysisAI

# 日志：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_FILE=logs/goldanalysisai.log

# LLM 分析（默认关闭）
# 硅基流动示例：
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro
# LLM_MODEL_FAST=deepseek-ai/DeepSeek-V4-Pro
# LLM_MODEL_STRONG=deepseek-ai/DeepSeek-V4-Pro
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_STRONG=gpt-4o-mini
LLM_TIMEOUT=120
LLM_ENHANCE_CONCLUSION=true

# 智能体流水线模式：rule | llm | hybrid
AGENT_MODE=rule
LLM_OVERRIDE_THRESHOLD=0.65
LLM_STAGE_RESEARCH=false
LLM_STAGE_DEBATE=false
LLM_STAGE_ANALYSTS=false
# 可选：仅调试单个 Analyst LLM（technical / fundamentals / news / sentiment；留空或 all 为全部）
LLM_ANALYST_ONLY=
LLM_STAGE_ICT=false
LLM_STAGE_LEVELS=false
LLM_STAGE_TRADER=false
LLM_STAGE_RISK=false
LLM_STAGE_MANAGER=false
